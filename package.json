{
  "name": "git-obsidian",
  "version": "1.0.0",
  "description": "Obsidian plugin that syncs vault notes with GitHub over HTTPS.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src tests eslint.config.mts"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "git",
    "sync"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@types/node": "^22.15.30",
    "esbuild": "0.25.5",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "tslib": "2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
